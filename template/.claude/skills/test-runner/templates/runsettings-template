## 完整模板（含覆盖率阈值）

```xml
<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <!-- 测试运行器配置 -->
  <RunConfiguration>
    <TestSessionTimeout>600000</TestSessionTimeout>
    <ContinueOnError>false</ContinueOnError>
    <MaxCpuCount>4</MaxCpuCount>
    <TargetPlatform>x64</TargetPlatform>
    <TargetFrameworkVersion>net8.0</TargetFrameworkVersion>
    
    <!-- 日志配置 -->
    <ResultsDirectory>./TestResults</ResultsDirectory>
  </RunConfiguration>

  <!-- xUnit 特定配置 -->
  <XUnit>
    <!-- 并行运行测试类 -->
    <MaxParallelThreads>4</MaxParallelThreads>
    
    <!-- 测试发现超时（毫秒） -->
    <DiscoveryTimeout>300000</DiscoveryTimeout>
  </XUnit>

  <!-- 代码覆盖率配置 -->
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="Code Coverage" uri="datacollector://Microsoft/CodeCoverage/2.0" assemblyQualifiedName="Microsoft.VisualStudio.Coverage.DynamicCoverageDataCollector, Microsoft.VisualStudio.TraceCollector, Version=11.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
        <Configuration>
          <CodeCoverage>
            <!-- 包含的模块 -->
            <ModulePaths>
              <Include>
                <ModulePath>.*CompanyName\.ProjectName\.(Api|Application|Domain|Infrastructure)\.dll$</ModulePath>
              </Include>
            </ModulePaths>
            
            <!-- 排除的模块 -->
            <ModulePaths>
              <Exclude>
                <ModulePath>.*Tests\.dll$</ModulePath>
                <ModulePath>.*\.Test\.dll$</ModulePath>
              </Exclude>
            </ModulePaths>
            
            <!-- 包含的源代码文件 -->
            <Sources>
              <Include>
                <SourcePath>.*\\(Api|Application|Domain|Infrastructure)\\</SourcePath>
              </Include>
            </Sources>
          </CodeCoverage>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>

  <!-- 覆盖率阈值（通过测试插件检查） -->
  <CoverageThresholds>
    <LineCoverage>80</LineCoverage>
    <BranchCoverage>70</BranchCoverage>
    <MethodCoverage>80</MethodCoverage>
  </CoverageThresholds>
</RunSettings>
```

