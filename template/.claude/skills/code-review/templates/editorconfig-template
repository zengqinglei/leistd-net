## .NET 项目模板

```editorconfig
# https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C# 代码特定设置
[*.cs]
indent_size = 4
csharp_new_line_before_open_brace_type = all
csharp_new_line_before_open_brace_method = all
csharp_new_line_before_open_brace_property = all
csharp_new_line_before_open_brace_event = all
csharp_new_line_before_open_brace_field = all
csharp_new_line_before_open_brace_anonymous_types = all
csharp_new_line_before_open_brace_anonymous_methods = all
csharp_new_line_before_open_brace_control_blocks = all
csharp_new_line_before_open_brace_accessors = all
csharp_new_line_before_open_brace_lambda_expressions = all

# C# 命名规则
csharp_style_var_for_built_in_types = false
csharp_style_var_when_type_is_apparent = true
csharp_style_var_elsewhere = false

# C# 代码风格
csharp_style_expression_bodied_methods = when_on_single_line
csharp_style_expression_bodied_constructors = when_on_single_line
csharp_style_expression_bodied_operators = when_on_single_line
csharp_style_expression_bodied_properties = true
csharp_style_expression_bodied_indexers = true
csharp_style_expression_bodied_accessors = true

# C# 空格规则
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_parentheses = false
csharp_space_between_square_brackets = false

# C# 换行规则
csharp_using_directive_placement = outside_namespace:silent
```

