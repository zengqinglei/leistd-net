{
  "ConnectionStrings": {
    "Default": ""
  },
  "OAuth": {
    "CookieExpireDays": 7,
    "UseDevelopmentCertificates": true,
    "DisableHttpsRequirement": false,
    "Resource": "myproject-api"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowAnyLocalhost": false,
    "AllowedOrigins": []
  },
  "DefaultAdmin": {
    "Username": "admin",
    "Password": "Admin@123456",
    "Email": "admin@myproject.com",
    "Nickname": "系统管理员"
  },
  "Encryption": {
    "Key": "tYpx0UYG9OPSBeeIrKFucrJ0oni3SFOPjZNFjsXjItM="
  },
  "UserRegistration": {
    "EnableEmailVerification": false,
    "CaptchaExpiryMinutes": 5,
    "EmailCodeExpiryMinutes": 5,
    "EmailCodeSendIntervalSeconds": 60
  },
  "Leistd": {
    "GlobalException": {
      "Enable": true,
      "ExcludePathPatterns": []
    }
  }
}
